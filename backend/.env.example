# ============================================================
# Study Library ERP — Backend Environment Variables
# Copy this file to .env and fill in your credentials
# ============================================================

# Server
NODE_ENV=development
PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/library-erp?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_very_long_and_random_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_very_long_and_random_refresh_secret_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Seed Admin (used only during db seed)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@library.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_LIBRARY_NAME=My Study Library
